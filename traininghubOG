    function init() {
    if (repEmail) {
      showPortal(repEmail);
      loadProgressFromZoho(repEmail);
    }
  }

  function submitEmail() {
    const input = document.getElementById('emailInput');
    const val = input.value.trim().toLowerCase();
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
    if (!valid) {
      input.classList.add('error');
      document.getElementById('gateError').classList.add('show');
      return;
    }
    repEmail = val;
    localStorage.setItem(KEY_EMAIL, repEmail);

    const btn = document.getElementById('gateBtn');
    btn.classList.add('loading');
    btn.disabled = true;

    loadProgressFromZoho(repEmail, () => {
      btn.classList.remove('loading');
      btn.disabled = false;
      showPortal(repEmail);
    });
  }

  document.getElementById('emailInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') submitEmail();
    document.getElementById('emailInput').classList.remove('error');
    document.getElementById('gateError').classList.remove('show');
  });

  function showPortal(email) {
    document.getElementById('gateOverlay').classList.add('hidden');
    document.getElementById('navEmail').textContent = email;
    updateUI();
    setTimeout(() => {
      document.getElementById('globalProgress').style.width =
        Math.round(completed.size / TOTAL_MODULES * 100) + '%';
    }, 250);
  }

  function loadProgressFromZoho(email, callback) {
    if (!ZOHO_WEBHOOK_READ) {
      if (callback) callback();
      return;
    }
    fetch(ZOHO_WEBHOOK_READ, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    })
      .then(r => r.json())
      .then(data => {
        if (data && Array.isArray(data.completed)) {
          completed = new Set(data.completed);
          localStorage.setItem(KEY_COMPLETED, JSON.stringify([...completed]));
        }
        if (data && Array.isArray(data.quizPassed)) {
          quizPassed = new Set(data.quizPassed);
          localStorage.setItem(KEY_QUIZ_PASSED, JSON.stringify([...quizPassed]));
        }
        if (callback) callback();
      })
      .catch(() => {
        if (callback) callback();
      });
  }

  function resetSession() {
    if (!confirm('Switch account? Your progress is saved locally (and may be saved in Zoho if enabled).')) return;
    localStorage.removeItem(KEY_EMAIL);
    localStorage.removeItem(KEY_COMPLETED);
    localStorage.removeItem(KEY_QUIZ_PASSED);
    location.reload();
  }

  function isStageUnlocked(stageNum) {
    if (stageNum === 1) return true;
    const prev = stageNum - 1;
    const prevCount = STAGE_MODULE_COUNTS[prev] || 0;
    for (let m = 1; m <= prevCount; m++) {
      if (!completed.has('stage' + prev + '-' + m)) return false;
    }
    return true;
  }

  function isStageComplete(stageNum) {
    const count = STAGE_MODULE_COUNTS[stageNum] || 0;
    for (let m = 1; m <= count; m++) {
      if (!completed.has('stage' + stageNum + '-' + m)) return false;
    }
    return true;
  }

  function updateUI() {
    // module done styling
    document.querySelectorAll('.module-item').forEach(item => {
      const oc = item.getAttribute('onclick');
      const match = oc && oc.match(/'([^']+)',\s*'([^']+)',\s*(\d+)/);
      if (match && completed.has(match[2])) {
        item.classList.add('done');
        item.querySelector('.module-icon').textContent = '✓';
      }
    });

    // stage lock/completion states
    for (let s = 1; s <= TOTAL_STAGES; s++) {
      const card = document.getElementById('stage' + s);
      const banner = card.querySelector('.lock-banner');
      const badge = card.querySelector('.stage-badge');

      if (isStageComplete(s)) {
        card.classList.remove('locked');
        card.classList.add('completed');
        badge.textContent = 'Stage ' + s + ' ✓';
      } else if (isStageUnlocked(s)) {
        card.classList.remove('locked', 'completed');
        badge.textContent = 'Stage ' + s;
      } else {
        card.classList.add('locked');
        card.classList.remove('completed');
        badge.textContent = 'Stage ' + s;
        if (banner) banner.textContent = '🔒 Complete Stage ' + (s - 1) + ' to unlock';
      }
    }

    const done = completed.size;
    const pct = Math.round(done / TOTAL_MODULES * 100);
    document.getElementById('globalProgress').style.width = pct + '%';
    document.getElementById('progressLabel').textContent = done + ' of ' + TOTAL_MODULES + ' modules complete';
    document.getElementById('progressPct').textContent = pct + '%';
    document.getElementById('doneCount').textContent = done;
  }

