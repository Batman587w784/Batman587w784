    body.innerHTML = meta ? meta.html : '';

    const videoLabel = document.getElementById('videoLabel');
    if (meta && meta.type === 'task') {
      videoLabel.textContent = 'Task module — complete the checklist below, then mark complete.';
    } else {
      videoLabel.textContent = 'Replace this with your Loom/YouTube/Vimeo embed later';
    }

    renderQuiz(id);

    const btn = document.getElementById('markBtn');
    if (completed.has(id)) {
      btn.textContent = '✓ Already Completed';
      btn.classList.add('done');
      btn.disabled = true;
    } else {
      const passed = quizPassed.has(id) || !QUIZZES[id];
      btn.textContent = passed ? 'Mark Complete ✓' : 'Complete Quiz to Unlock';
      btn.classList.remove('done');
      btn.disabled = !passed;
    }
  }
   function closeModal() {
    document.getElementById('modalOverlay').classList.remove('open');
    currentModule = null;
  }

  function closeModalOutside(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  function markDone() {
    if (!currentModule || completed.has(currentModule.id)) return;

    const { id, name, stage } = currentModule;

    // quiz gating only if quiz exists for module
    if (QUIZZES[id] && !quizPassed.has(id)) {
      showToast('Pass the quiz first to unlock completion.', 'error');
      return;
    }

    completed.add(id);
    localStorage.setItem(KEY_COMPLETED, JSON.stringify([...completed]));
    updateUI();

    const btn = document.getElementById('markBtn');
    btn.textContent = '✓ Already Completed';
    btn.classList.add('done');
    btn.disabled = true;

    const justCompletedStage = isStageComplete(stage);
    sendToZoho({ id, name, stage, justCompletedStage });
  }

  function sendToZoho({ id, name, stage, justCompletedStage }) {
    const payload = {
      email: repEmail,
      stage: stage,
      module_id: id,
      module_name: name,
      completed_at: new Date().toISOString(),
      stage_complete: justCompletedStage,
      completed: [...completed],
      quizPassed: [...quizPassed]
    };

    fetch(ZOHO_WEBHOOK_WRITE, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
      .then(res => {
        if (res.ok) {
          const msg = justCompletedStage
            ? '🎉 Stage ' + stage + ' complete — synced!'
            : '✓ Progress synced';
          showToast(msg, 'success');
        } else {
          showToast('⚠ Saved locally — sync failed', 'error');
        }
      })
      .catch(() => {
        showToast('⚠ Saved locally — check connection', 'error');
      });
  }

  function renderQuiz(moduleId) {
    const wrap = document.getElementById('quizWrap');
    const form = document.getElementById('quizForm');
    const score = document.getElementById('quizScore');

    score.textContent = '';
    score.className = 'quiz-score';

    const quiz = QUIZZES[moduleId];
    if (!quiz) {
      wrap.style.display = 'none';
      return;
    }
    wrap.style.display = 'block';

    form.innerHTML = quiz.questions.map((q, idx) => {
      const n = 'q_' + moduleId + '_' + q.id;

      if (q.type === 'mc') {
        return '<div class="q"><div class="qtext">' + (idx + 1) + '. ' + escapeHtml(q.text) + '</div><div class="opts">' +
          q.options.map(opt =>
            '<label><input type="radio" name="' + escapeAttr(n) + '" value="' + escapeAttr(opt) + '"> <span>' + escapeHtml(opt) + '</span></label>'
          ).join('') +
          '</div></div>';
      }

      if (q.type === 'tf') {
        return '<div class="q"><div class="qtext">' + (idx + 1) + '. ' + escapeHtml(q.text) + '</div><div class="opts">' +
          '<label><input type="radio" name="' + escapeAttr(n) + '" value="true"> <span>True</span></label>' +
          '<label><input type="radio" name="' + escapeAttr(n) + '" value="false"> <span>False</span></label>' +
          '</div></div>';
      }

      // short
      return '<div class="q"><div class="qtext">' + (idx + 1) + '. ' + escapeHtml(q.text) + '</div>' +
        '<input type="text" name="' + escapeAttr(n) + '" placeholder="Type your answer…">' +
        '</div>';
    }).join('');
  }
    function submitQuiz() {
    if (!currentModule) return;
    const id = currentModule.id;
    const quiz = QUIZZES[id];
    if (!quiz) return;

    let correct = 0;
    const total = quiz.questions.length;

    for (const q of quiz.questions) {
      const n = 'q_' + id + '_' + q.id;

      const getChecked = () => document.querySelector('[name="' + cssEscape(n) + '"]:checked')?.value;
      const getText = () => (document.querySelector('[name="' + cssEscape(n) + '"]')?.value || '').trim();

      if (q.type === 'tf') {
        const val = getChecked();
        const b = (val === 'true');
        if (val !== undefined && b === q.answer) correct++;
        continue;
      }

      if (q.type === 'mc') {
        const val = getChecked();
        if (val === q.answer) correct++;
        continue;
      }

      // short (lenient keyword match if provided)
      const val = getText().toLowerCase();
      if (!q.answerContains || q.answerContains.length === 0) {
        if (val.length >= 6) correct++; // basic “answered something”
        continue;
      }
      const keys = q.answerContains.map(s => String(s).toLowerCase());
      const hits = keys.filter(k => val.includes(k)).length;
      const threshold = Math.max(1, Math.ceil(keys.length / 2));
      if (hits >= threshold) correct++;
    }

    const pct = Math.round((correct / total) * 100);
    const score = document.getElementById('quizScore');
    score.textContent = `Score: ${pct}% (${correct}/${total}) — ${pct >= QUIZ_PASS_PCT ? 'PASS' : 'RETRY'}`;
    score.className = 'quiz-score ' + (pct >= QUIZ_PASS_PCT ? 'pass' : 'fail');

    if (pct >= QUIZ_PASS_PCT) {
      quizPassed.add(id);
      localStorage.setItem(KEY_QUIZ_PASSED, JSON.stringify([...quizPassed]));

      const btn = document.getElementById('markBtn');
      if (!completed.has(id)) {
        btn.textContent = 'Mark Complete ✓';
        btn.disabled = false;
      }

      showToast('✅ Quiz passed — you can mark this module complete.', 'success');
    } else {
      showToast('❌ Quiz not passed — try again.', 'error');
    }
  }

  function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast show ' + (type || '');
    clearTimeout(window.__tg_toast);
    window.__tg_toast = setTimeout(() => {
      t.className = 'toast';
    }, 2400);
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }
  function escapeAttr(s) {
    return escapeHtml(s).replace(/`/g, '&#96;');
  }
  function cssEscape(s) {
    // safe enough for our generated names
    return String(s).replace(/"/g, '\\"');
  }

  // Boot
  init();
</script>
