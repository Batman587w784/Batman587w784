<!--
Tailgate — Sales Training Portal (with Stage 1 Quiz Gating)
Updated: 2026-02-21

Single-file static portal:
- 5 stages + unlock logic
- Quizzes on Stages 1, 2, and 4 only (80% pass)
- Stage 5 includes training review module
- “Final Pack” resources always accessible
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tailgate — Training Hub</title>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --white:#ffffff; --off-white:#f7f8fc; --light:#eef0f7;
      --blue:#1a3adb; --blue-mid:#2f4ef0; --blue-light:#e8ecff;
      --red:#e5141f; --red-light:#fff0f0;
      --dark:#0d0f1a; --gray:#6b7280; --gray-light:#d1d5db;
      --border:#e5e7ef;
      --shadow:0 2px 12px rgba(26,58,219,0.08);
      --shadow-lg:0 8px 40px rgba(26,58,219,0.13);
      --green:#1a7a4a; --green-light:#e6f7ef;
      --locked-bg:#f9f9fb;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      background:var(--off-white);
      color:var(--dark);
      font-family:'Instrument Sans', sans-serif;
      font-weight:400;
      min-height:100vh;
      overflow-x:hidden;
    }

    /* Gate overlay */
    .gate-overlay { position:fixed; inset:0; background:rgba(13,15,26,0.75); backdrop-filter:blur(8px); z-index:300; display:flex; align-items:center; justify-content:center; padding:20px; }
    .gate-overlay.hidden { display:none; }
    .gate-card { background:var(--white); border:1.5px solid var(--border); border-radius:22px; padding:40px; width:100%; max-width:420px; box-shadow:0 24px 80px rgba(13,15,26,0.2); animation:modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1); }
    .gate-eyebrow { font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--blue); margin-bottom:10px; }
    .gate-title { font-family:'Bricolage Grotesque', sans-serif; font-weight:800; font-size:1.7rem; letter-spacing:-0.03em; color:var(--dark); margin-bottom:8px; line-height:1.1; }
    .gate-sub { font-size:0.88rem; color:var(--gray); line-height:1.6; margin-bottom:28px; }
    .gate-label { font-size:0.78rem; font-weight:600; color:var(--dark); margin-bottom:8px; display:block; }
    .gate-input { width:100%; padding:12px 16px; border:1.5px solid var(--border); border-radius:10px; font-family:'Instrument Sans', sans-serif; font-size:0.95rem; color:var(--dark); background:var(--off-white); outline:none; transition:border-color 0.2s, box-shadow 0.2s; margin-bottom:16px; }
    .gate-input:focus { border-color:var(--blue); box-shadow:0 0 0 3px var(--blue-light); background:var(--white); }
    .gate-input.error { border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
    .gate-error { font-size:0.78rem; color:var(--red); margin-top:-10px; margin-bottom:14px; display:none; }
    .gate-error.show { display:block; }
    .gate-btn { width:100%; padding:13px; background:var(--blue); color:white; border:none; border-radius:10px; font-family:'Instrument Sans', sans-serif; font-size:0.95rem; font-weight:600; cursor:pointer; transition:background 0.18s, transform 0.18s; display:flex; align-items:center; justify-content:center; gap:8px; }
    .gate-btn:hover { background:var(--blue-mid); }
    .gate-btn:disabled { opacity:0.6; cursor:not-allowed; }
    .gate-spinner { width:16px; height:16px; border:2px solid rgba(255,255,255,0.4); border-top-color:white; border-radius:50%; animation:spin 0.7s linear infinite; display:none; }
    .gate-btn.loading .gate-spinner { display:block; }
    .gate-btn.loading .gate-btn-text { opacity:0.7; }
    @keyframes spin { to { transform:rotate(360deg);} }

    /* Nav */
    nav { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:0 40px; height:64px; background:var(--white); border-bottom:1.5px solid var(--border); }
    .logo { font-family:'Bricolage Grotesque', sans-serif; font-weight:800; font-size:1.35rem; letter-spacing:-0.04em; color:var(--dark); }
    .logo span { color:var(--blue); }
    .nav-right { display:flex; align-items:center; gap:10px; }
    .nav-email { font-size:0.78rem; font-weight:500; color:var(--gray); background:var(--off-white); border:1.5px solid var(--border); padding:5px 12px; border-radius:20px; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .nav-badge { font-size:0.72rem; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:var(--blue); background:var(--blue-light); padding:5px 12px; border-radius:20px; }
    .nav-reset { font-size:0.72rem; font-weight:600; color:var(--gray); background:none; border:1.5px solid var(--border); padding:5px 10px; border-radius:20px; cursor:pointer; transition:all 0.15s; }
    .nav-reset:hover { color:var(--red); border-color:rgba(229,20,31,0.3); }
    .nav-link { font-size:0.72rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:var(--blue); background:var(--blue-light); border:1.5px solid rgba(26,58,219,0.2); padding:6px 10px; border-radius:20px; text-decoration:none; transition:all 0.15s; }
    .nav-link:hover { background:var(--blue); color:white; }

    /* Module body + resources */
    .module-body { padding:18px 24px 6px; }
    .module-body h3 { font-family:'Bricolage Grotesque', sans-serif; font-weight:800; letter-spacing:-0.02em; font-size:1rem; margin-bottom:8px; }
    .module-body p { font-size:0.9rem; color:var(--gray); line-height:1.7; margin-bottom:10px; }
    .task-box { background:var(--off-white); border:1.5px solid var(--border); border-radius:14px; padding:14px; }
    .task-box ul { margin-left:18px; color:var(--dark); }
    .task-box li { margin:8px 0; line-height:1.5; }

    .resource-links { display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:12px; }
    .resource-link { display:block; padding:14px 14px; border-radius:14px; border:1.5px solid var(--border); background:var(--white); text-decoration:none; color:var(--dark); box-shadow:var(--shadow); transition:transform 0.18s, box-shadow 0.18s, border-color 0.18s; }
    .resource-link:hover { transform:translateY(-2px); box-shadow:var(--shadow-lg); border-color:rgba(26,58,219,0.22); }
    .resource-link .t { font-weight:800; letter-spacing:-0.02em; font-family:'Bricolage Grotesque', sans-serif; margin-bottom:6px; }
    .resource-link .s { font-size:0.82rem; color:var(--gray); line-height:1.5; }

    /* Hero */
    .hero { padding:108px 40px 56px; max-width:1140px; margin:0 auto; display:grid; grid-template-columns:1fr auto; gap:40px; align-items:end; }
    .hero-eyebrow { display:inline-flex; align-items:center; gap:8px; font-size:0.78rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:var(--red); margin-bottom:18px; }
    .hero-eyebrow::before { content:''; display:block; width:22px; height:2.5px; background:var(--red); border-radius:2px; }
    .hero h1 { font-family:'Bricolage Grotesque', sans-serif; font-weight:800; font-size:clamp(2.6rem, 5.5vw, 4.8rem); line-height:1.02; letter-spacing:-0.04em; margin-bottom:20px; color:var(--dark); }
    .hero h1 .blue { color:var(--blue); } .hero h1 .red { color:var(--red); }
    .hero p { font-size:1.05rem; color:var(--gray); max-width:480px; line-height:1.7; margin-bottom:32px; }
    .progress-meta { display:flex; justify-content:space-between; margin-bottom:8px; }
    .progress-meta span { font-size:0.82rem; font-weight:600; color:var(--gray); }
    .progress-meta .pct { color:var(--blue); }
    .progress-track { width:100%; max-width:400px; height:7px; background:var(--light); border-radius:10px; overflow:hidden; border:1px solid var(--border); }
    .progress-fill { height:100%; width:0%; background:linear-gradient(90deg, var(--blue), var(--blue-mid)); border-radius:10px; transition:width 1s cubic-bezier(0.4,0,0.2,1); }
    .hero-stats { display:flex; flex-direction:column; gap:10px; }
    .stat-pill { background:var(--white); border:1.5px solid var(--border); border-radius:14px; padding:14px 20px; text-align:right; box-shadow:var(--shadow); min-width:140px; }
    .stat-pill .num { font-family:'Bricolage Grotesque', sans-serif; font-weight:800; font-size:1.7rem; letter-spacing:-0.04em; line-height:1; color:var(--blue); margin-bottom:4px; }
    .stat-pill .num.red { color:var(--red); }
    .stat-pill .lbl { font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:var(--gray); }

    /* Sections */
    .section { max-width:1140px; margin:0 auto; padding:56px 40px; }
    .divider { height:1.5px; background:var(--border); margin:0 40px; }
    .section-label { font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--blue); margin-bottom:6px; }
    .section-title { font-family:'Bricolage Grotesque', sans-serif; font-weight:800; font-size:clamp(1.5rem, 2.5vw, 2rem); letter-spacing:-0.03em; color:var(--dark); line-height:1.1; margin-bottom:28px; }

    /* Stage cards */
    .stages-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:16px; }
    .stage-card { background:var(--white); border:1.5px solid var(--border); border-radius:18px; padding:26px; transition:box-shadow 0.2s, transform 0.2s, border-color 0.2s; position:relative; }
    .stage-card:not(.locked):hover { box-shadow:var(--shadow-lg); transform:translateY(-2px); border-color:rgba(26,58,219,0.18); }
    .stage-card.locked { background:var(--locked-bg); border-color:var(--border); opacity:0.6; cursor:not-allowed; }
    .stage-card.locked .module-item { pointer-events:none; cursor:not-allowed; }
    .stage-card.locked .stage-badge { background:var(--light); color:var(--gray); }
    .lock-banner { display:none; align-items:center; gap:6px; font-size:0.75rem; font-weight:600; color:var(--gray); background:var(--light); border:1.5px solid var(--border); padding:6px 12px; border-radius:8px; margin-bottom:14px; }
    .stage-card.locked .lock-banner { display:flex; }
    .stage-card.completed { border-color:rgba(26,58,219,0.25); background:linear-gradient(135deg, #fff 80%, var(--blue-light)); }
    .stage-card.completed .stage-badge { background:var(--green-light); color:var(--green); }
    .stage-badge { display:inline-block; font-size:0.68rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:var(--blue-light); color:var(--blue); padding:4px 10px; border-radius:20px; margin-bottom:12px; }
    .stage-title { font-family:'Bricolage Grotesque', sans-serif; font-weight:700; font-size:1.08rem; letter-spacing:-0.02em; margin-bottom:8px; color:var(--dark); line-height:1.3; }
    .stage-desc { font-size:0.84rem; color:var(--gray); line-height:1.6; margin-bottom:18px; }
    .stage-modules { display:flex; flex-direction:column; gap:7px; }

    /* Module rows */
    .module-item { display:flex; align-items:center; gap:10px; font-size:0.83rem; font-weight:500; color:var(--dark); padding:9px 12px; background:var(--off-white); border-radius:10px; border:1.5px solid var(--border); cursor:pointer; transition:all 0.18s ease; }
    .module-item:hover { background:var(--blue-light); border-color:rgba(26,58,219,0.2); color:var(--blue); }
    .module-item.done { color:var(--green); background:var(--green-light); border-color:rgba(26,122,74,0.2); }
    .module-icon { width:22px; height:22px; border-radius:50%; background:var(--blue); color:white; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:9px; padding-left:1px; transition:background 0.18s; }
    .module-item:hover .module-icon { background:var(--blue-mid); }
    .module-item.done .module-icon { background:var(--green); padding-left:0; font-size:11px; }
    .locked .module-icon { background:var(--gray-light); }

  .modal-overlay { position:fixed; inset:0; background:rgba(13,15,26,0.6); backdrop-filter:blur(6px); z-index:200; display:none; align-items:center; justify-content:center; padding:20px; }
.modal-overlay.open { display:flex; }

/* Sticky modal layout */
.modal{
  background:var(--white);
  border:1.5px solid var(--border);
  border-radius:22px;
  width:100%;
  max-width:760px;
  max-height:90vh;
  overflow:hidden;
  box-shadow:0 24px 80px rgba(13,15,26,0.2);
  animation:modalIn 0.28s cubic-bezier(0.34,1.56,0.64,1);
  display:flex;
  flex-direction:column;
}

@keyframes modalIn { from { opacity:0; transform:scale(0.92) translateY(16px);} to { opacity:1; transform:scale(1) translateY(0);} }

.modal-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:20px 24px;
  border-bottom:1.5px solid var(--border);
  position:sticky;
  top:0;
  z-index:10;
  background:var(--white);
}

.modal-stage-tag { font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--blue); background:var(--blue-light); padding:3px 10px; border-radius:20px; margin-bottom:4px; display:inline-block; }
.modal-title { font-family:'Bricolage Grotesque', sans-serif; font-weight:700; font-size:1.05rem; letter-spacing:-0.02em; color:var(--dark); }

.modal-close { width:34px; height:34px; border-radius:50%; background:var(--light); border:1.5px solid var(--border); color:var(--gray); font-size:1rem; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; flex-shrink:0; }
.modal-close:hover { background:var(--red-light); border-color:rgba(229,20,31,0.2); color:var(--red); }

/* The scrolling middle area */
.modal-scroll{
  overflow-y:auto;
  -webkit-overflow-scrolling:touch;
}

/* Sticky footer */
.modal-footer{
  padding:16px 24px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  position:sticky;
  bottom:0;
  z-index:10;
  background:var(--white);
  border-top:1.5px solid var(--border);
}

    /* Video placeholder */
    .video-placeholder { aspect-ratio:16/9; background:var(--off-white); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:14px; position:relative; border-bottom:1.5px solid var(--border); overflow:hidden; }
    .video-bg-pattern { position:absolute; inset:0; background-image:radial-gradient(circle, var(--border) 1px, transparent 1px); background-size:24px 24px; opacity:0.6; }
    .play-btn { width:64px; height:64px; border-radius:50%; background:var(--blue); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1.3rem; color:white; position:relative; z-index:1; padding-left:4px; box-shadow:0 8px 32px rgba(26,58,219,0.35); transition:transform 0.18s, box-shadow 0.18s, background 0.18s; }
    .play-btn:hover { transform:scale(1.08); background:var(--blue-mid); }
    .video-label { font-size:0.82rem; font-weight:500; color:var(--gray); position:relative; z-index:1; }

    /* Quiz */
    .quiz { padding:18px 24px; border-bottom:1.5px solid var(--border); background:linear-gradient(180deg,#fff,#fafbff); }
    .quiz-head { display:flex; align-items:baseline; justify-content:space-between; gap:12px; margin-bottom:12px; }
    .quiz-title { font-family:'Bricolage Grotesque',sans-serif; font-weight:800; letter-spacing:-0.02em; }
    .quiz-sub { font-size:.8rem; color:var(--gray); }
    .quiz-form { display:flex; flex-direction:column; gap:12px; }
    .q { background:var(--off-white); border:1.5px solid var(--border); border-radius:12px; padding:12px; }
    .q .qtext { font-size:.86rem; font-weight:600; color:var(--dark); margin-bottom:8px; line-height:1.4; }
    .q .opts { display:flex; flex-direction:column; gap:6px; }
    .q label { font-size:.84rem; color:var(--dark); display:flex; gap:8px; align-items:flex-start; }
    .q input[type="text"] { width:100%; padding:10px 12px; border:1.5px solid var(--border); border-radius:10px; background:#fff; font-family:'Instrument Sans',sans-serif; }
    .quiz-actions { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-top:10px; }
    .quiz-score { font-size:.85rem; font-weight:600; color:var(--gray); }
    .quiz-score.pass { color:var(--green); }
    .quiz-score.fail { color:var(--red); }

    .modal-footer { padding:16px 24px; display:flex; align-items:center; justify-content:space-between; gap:16px; }
    .upload-hint { font-size:0.78rem; color:var(--gray); }
    .upload-hint strong { color:var(--blue); font-weight:600; }
    .btn-mark { background:var(--blue); color:white; border:none; padding:10px 22px; border-radius:10px; font-family:'Instrument Sans',sans-serif; font-size:0.85rem; font-weight:600; cursor:pointer; transition:background 0.18s, transform 0.18s; white-space:nowrap; }
    .btn-mark:hover:not(:disabled) { background:var(--blue-mid); transform:scale(1.02); }
    .btn-mark.done { background:var(--green); }
    .btn-mark:disabled { opacity:0.6; cursor:not-allowed; transform:none; }

    /* Footer + toast */
    footer { max-width:1140px; margin:24px auto 0; padding:32px 40px; display:flex; align-items:center; justify-content:space-between; border-top:1.5px solid var(--border); }
    .footer-logo { font-family:'Bricolage Grotesque',sans-serif; font-weight:800; font-size:1rem; letter-spacing:-0.03em; color:var(--gray); }
    .footer-logo span { color:var(--blue); }
    .footer-text { font-size:0.78rem; color:var(--gray-light); }

    .toast { position:fixed; bottom:28px; left:50%; transform:translateX(-50%) translateY(80px); background:var(--dark); color:white; padding:12px 20px; border-radius:12px; font-size:0.85rem; font-weight:500; box-shadow:0 8px 32px rgba(0,0,0,0.2); z-index:400; transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1); white-space:nowrap; }
    .toast.show { transform:translateX(-50%) translateY(0); }
    .toast.success { background:var(--green); }
    .toast.error { background:var(--red); }

    /* Mobile */
    @media (max-width:700px) {
      nav { padding:0 16px; }
      .nav-email { display:none; }
      .hero { padding:90px 20px 40px; grid-template-columns:1fr; }
      .hero-stats { flex-direction:row; }
      .section { padding:40px 20px; }
      .divider { margin:0 20px; }
      footer { padding:24px 20px; flex-direction:column; gap:8px; text-align:center; }
    }
  </style>
</head>
<body>

<div class="gate-overlay" id="gateOverlay">
  <div class="gate-card">
    <div class="gate-eyebrow">🏈 Tailgate Training Hub</div>
    <div class="gate-title">Welcome to the team.</div>
    <div class="gate-sub">Enter your work email to get started. We'll load your progress automatically — use the same email you were onboarded with.</div>
    <label class="gate-label" for="emailInput">Work email</label>
    <input class="gate-input" type="email" id="emailInput" placeholder="you@tailgate.com" autocomplete="email" />
    <div class="gate-error" id="gateError">Please enter a valid email address.</div>
    <button class="gate-btn" id="gateBtn" onclick="submitEmail()">
      <span class="gate-btn-text">Load My Progress →</span>
      <div class="gate-spinner"></div>
    </button>
  </div>
</div>

<nav>
  <div class="logo">Tail<span>gate</span></div>
  <div class="nav-right">
    <a class="nav-link" href="#finalPack">Final Pack</a>
    <div class="nav-email" id="navEmail"></div>
    <div class="nav-badge">Training</div>
    <button class="nav-reset" onclick="resetSession()" title="Switch account">↩ Switch</button>
  </div>
</nav>

<div class="hero">
  <div class="hero-left">
    <div class="hero-eyebrow">5-Stage Bootcamp</div>
    <h1>Close more.<br><span class="blue">Sell</span> <span class="red">smarter.</span></h1>
    <p>Your onboarding hub for Tailgate's team. Complete each stage to unlock the next — your progress syncs automatically.</p>

    <div class="progress-wrap">
      <div class="progress-meta">
        <span id="progressLabel">0 of 16 modules complete</span>
        <span class="pct" id="progressPct">0%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="globalProgress"></div>
      </div>
    </div>
  </div>

  <div class="hero-stats">
    <div class="stat-pill"><div class="num">16</div><div class="lbl">Modules</div></div>
    <div class="stat-pill"><div class="num red">5</div><div class="lbl">Stages</div></div>
    <div class="stat-pill"><div class="num" id="doneCount">0</div><div class="lbl">Done</div></div>
  </div>
</div>

<div class="divider"></div>

<div class="section">
  <div class="section-label">Training Program</div>
  <div class="section-title">5 Stages to Closing</div>

  <div class="stages-grid">
      
      <div class="stage-card" id="stage1">
      <div class="stage-badge">Stage 1</div>
      <div class="lock-banner">🔒 Complete Stage 1 to unlock</div>
      <div class="stage-title">Culture, Product & Customers</div>
      <div class="stage-desc">Tailgate culture + how the NFC system works + how to build trust with different customer types.</div>
      <div class="stage-modules">
        <div class="module-item" onclick="openModal('Welcome to Tailgate: Culture & Standards', 'stage1-1', 1)"><div class="module-icon">▶</div> Welcome to Tailgate: Culture & Standards</div>
        <div class="module-item" onclick="openModal('NFC Intro: How Tailgate Works (Buddy Demo)', 'stage1-2', 1)"><div class="module-icon">▶</div> NFC Intro: How Tailgate Works (Buddy Demo)</div>
        <div class="module-item" onclick="openModal('Customer Types + Trust', 'stage1-3', 1)"><div class="module-icon">▶</div> Customer Types + Trust</div>
      </div>
    </div>

    <div class="stage-card" id="stage2">
      <div class="stage-badge">Stage 2</div>
