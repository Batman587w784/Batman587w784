        <svg viewBox="0 0 100 100" width="120" height="120">
          <circle class="mini-ring-bg" cx="50" cy="50" r="44"/>
          <circle class="mini-ring-progress" id="mini-ring" cx="50" cy="50" r="44"/>
        </svg>
        <div class="mini-cd-number" id="mini-number">30</div>
      </div>
