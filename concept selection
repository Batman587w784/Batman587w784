<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Choose Your Card Concept</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0A1F44;
    --red: #C8102E;
    --off-white: #F4F6FA;
    --card-bg: #FFFFFF;
    --border: #D6DCE8;
    --text: #0A1F44;
    --muted: #6B7A99;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--off-white); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; padding: 0 0 80px; }


  /* BACK ARROW */
  .back-arrow {
    position: fixed;
    top: 16px; left: 16px;
    z-index: 999;
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 18px;
    color: #fff;
    transition: background 0.2s;
    text-decoration: none;
  }
  .back-arrow:hover { background: rgba(255,255,255,0.28); }
  .back-arrow.dark {
    background: rgba(10,31,68,0.08);
    border-color: rgba(10,31,68,0.2);
    color: var(--navy);
  }
  .back-arrow.dark:hover { background: rgba(10,31,68,0.15); }

  /* ══ COUNTDOWN ══ */
  .countdown-screen {
    position: fixed; inset: 0;
    background: linear-gradient(135deg, var(--navy) 0%, #0d2a5e 100%);
    z-index: 500; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 40px;
  }
  .countdown-screen.hidden { animation: fadeOut 0.8s ease forwards; pointer-events: none; }
  @keyframes fadeOut { to { opacity: 0; visibility: hidden; } }

  .cd-logo-wrap { display: flex; flex-direction: column; align-items: center; gap: 10px; margin-bottom: 36px; }
  .cd-logo-img { width: 140px; height: auto; filter: brightness(0) invert(1); opacity: 0.9; }
  .cd-brand { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 4px; color: rgba(255,255,255,0.6); }
  .cd-brand span { color: var(--red); }
  .cd-powered { font-size: 11px; color: rgba(255,255,255,0.35); letter-spacing: 1px; margin-top: 2px; }

  .cd-label { font-size: 12px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 18px; }

  .ring-wrap { position: relative; width: 180px; height: 180px; margin-bottom: 28px; }
  .ring-wrap svg { position: absolute; inset: 0; transform: rotate(-90deg); }
  .ring-bg { fill: none; stroke: rgba(255,255,255,0.08); stroke-width: 6; }
  .ring-progress { fill: none; stroke: var(--red); stroke-width: 6; stroke-linecap: round; stroke-dasharray: 502; stroke-dashoffset: 0; transition: stroke-dashoffset 1s linear; }
  .cd-number { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 72px; color: #fff; letter-spacing: 2px; }

  .cd-msg { font-size: 14px; color: rgba(255,255,255,0.55); max-width: 340px; line-height: 1.7; margin-bottom: 28px; }
  .cd-msg strong { color: #fff; }

  .dots span { display: inline-block; animation: blink 1.4s infinite; opacity: 0; }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%,80%,100%{opacity:0} 40%{opacity:1} }

  .progress-steps { display: flex; gap: 20px; }
  .ps { display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.3); transition: color 0.4s; }
  .ps.done, .ps.active { color: rgba(255,255,255,0.9); }
  .ps .dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.2); transition: background 0.4s; }
  .ps.done .dot { background: var(--red); }
  .ps.active .dot { background: var(--red); animation: pulse 1s infinite; }
  @keyframes pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.4);opacity:0.7} }

  /* ══ MAIN CONTENT ══ */
  .main-content { display: none; }
  .main-content.visible { display: block; }

  /* HEADER */
  .header {
    background: linear-gradient(135deg, var(--navy) 0%, #122b5e 100%);
    border-bottom: 4px solid var(--red);
    padding: 28px 24px 24px; text-align: center; position: relative; overflow: hidden;
  }
  .header::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 0%, rgba(200,16,46,0.12) 0%, transparent 70%); }
  .header-logo-row { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 12px; position: relative; z-index: 1; }
  .header-logo-img { width: 80px; height: auto; filter: brightness(0) invert(1); opacity: 0.9; }
  .header-brand { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px; color: rgba(255,255,255,0.75); }
  .header-brand span { color: var(--red); }
  .org-badge { display: inline-block; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.3); border-radius: 999px; padding: 5px 16px; font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #fff; margin-bottom: 10px; position: relative; z-index: 1; }
  .header h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(28px, 5vw, 50px); letter-spacing: 3px; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; z-index: 1; }
  .header h1 span { color: var(--red); }
  .header p { color: rgba(255,255,255,0.6); font-size: 13px; max-width: 460px; margin: 0 auto 6px; line-height: 1.6; position: relative; z-index: 1; }
  .powered-by { font-size: 11px; color: rgba(255,255,255,0.35); letter-spacing: 0.5px; position: relative; z-index: 1; }
  .powered-by span { color: rgba(200,16,46,0.8); font-weight: 600; }

  /* STEPS */
  .steps { display: flex; justify-content: center; padding: 18px 24px; max-width: 600px; margin: 0 auto; }
  .step { display: flex; align-items: center; gap: 7px; font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); }
  .step.active { color: var(--navy); }
  .step-num { width: 22px; height: 22px; border-radius: 50%; background: var(--border); display: flex; align-items: center; justify-content: center; font-size: 10px; color: var(--muted); }
  .step.active .step-num { background: var(--navy); color: #fff; }
  .step-line { flex: 1; height: 1px; background: var(--border); margin: 0 10px; min-width: 24px; }

  /* GRID */
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 18px; max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  /* CARD */
  .card { background: var(--card-bg); border: 2px solid var(--border); border-radius: 16px; overflow: hidden; cursor: pointer; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; position: relative; }
  .card:hover { border-color: var(--navy); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(10,31,68,0.12); }
  .card.selected { border-color: var(--red); box-shadow: 0 0 0 1px var(--red), 0 12px 40px rgba(200,16,46,0.15); }
  .card.selected .select-btn { background: var(--navy); color: #fff; border-color: var(--navy); }
  .selected-badge { display: none; position: absolute; top: 12px; right: 12px; background: var(--red); color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 4px 10px; border-radius: 999px; z-index: 10; }
  .card.selected .selected-badge { display: block; }
  .option-label { position: absolute; top: 12px; left: 12px; background: var(--navy); border: 1px solid rgba(255,255,255,0.2); color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 4px 10px; border-radius: 999px; z-index: 10; }
  .card-image { width: 100%; aspect-ratio: 16/9; background: var(--off-white); position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--border); }
  .card-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; color: var(--muted); font-size: 13px; font-weight: 500; width: 100%; height: 100%; background: linear-gradient(135deg, #f0f3f9 0%, #e4e9f4 100%); }
  .placeholder-icon { font-size: 36px; opacity: 0.4; }
  .placeholder-bar {
    width: 60%; height: 4px; background: var(--border); border-radius: 999px; overflow: hidden; margin-top: 4px;
  }
  .placeholder-bar::after {
    content: '';
    display: block; height: 100%; width: 40%;
    background: linear-gradient(90deg, transparent, rgba(10,31,68,0.2), transparent);
    animation: shimmer 1.5s infinite;
  }
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(300%); }
  }
  .error-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; width: 100%; height: 100%; background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%); }
  .error-placeholder .error-icon { font-size: 32px; opacity: 0.5; }
  .error-placeholder .error-text { font-size: 12px; font-weight: 600; color: var(--red); opacity: 0.7; letter-spacing: 0.5px; }
  .error-placeholder .error-sub { font-size: 11px; color: var(--muted); }
  .card-body { padding: 16px 18px 18px; }
  .option-type { font-family: 'Bebas Neue', sans-serif; font-size: 21px; letter-spacing: 2px; color: var(--navy); margin-bottom: 4px; }
  .option-desc { font-size: 13px; color: var(--muted); line-height: 1.5; margin-bottom: 14px; }
  .tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 14px; }
  .tag { background: rgba(10,31,68,0.06); border: 1px solid rgba(10,31,68,0.18); color: var(--navy); font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 999px; }
  .select-btn { width: 100%; padding: 11px; background: transparent; border: 2px solid var(--border); border-radius: 8px; color: var(--navy); font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
  .select-btn:hover { border-color: var(--navy); background: var(--navy); color: #fff; }



  /* CONCEPT VARIABLE PREVIEWS */
  .concept-vars { margin-bottom: 24px; }
  .concept-vars-label { font-size: 13px; font-weight: 700; color: var(--navy); letter-spacing: 0.5px; margin-bottom: 10px; display: block; }
  .concept-vars-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .concept-var-btn {
    border: 2px solid var(--border); border-radius: 10px; overflow: hidden;
    cursor: pointer; transition: border-color 0.2s, transform 0.1s;
    background: #fff; text-align: left;
  }
  .concept-var-btn:hover { border-color: var(--navy); transform: translateY(-2px); }
  .concept-var-btn.active { border-color: var(--red); }
  .cvb-img {
    width: 100%; aspect-ratio: 16/9; object-fit: cover;
    background: linear-gradient(135deg, #e8ecf4, #d6dce8);
    display: block;
  }
  .cvb-img-placeholder {
    width: 100%; aspect-ratio: 16/9;
    background: linear-gradient(135deg, #e8ecf4, #d6dce8);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .cvb-label { padding: 7px 10px; font-size: 11px; font-weight: 700; color: var(--navy); letter-spacing: 0.5px; display: flex; align-items: center; justify-content: space-between; }
  .cvb-label span { color: var(--red); font-size: 10px; }

  /* 5TH CUSTOM CARD */
  .custom-card { border-color: rgba(200,16,46,0.3); }
  .custom-card:hover { border-color: var(--red); box-shadow: 0 12px 40px rgba(200,16,46,0.15); }
  .custom-card-inner {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 10px; padding: 24px; height: 100%; text-align: center;
  }
  .custom-card-icon { font-size: 40px; }
  .custom-card-title { font-family: "Bebas Neue", sans-serif; font-size: 22px; letter-spacing: 2px; color: #fff; }
  .custom-card-sub { font-size: 12px; color: rgba(255,255,255,0.55); line-height: 1.5; max-width: 200px; }
  .custom-card-btn {
    margin-top: 6px; background: var(--red); color: #fff;
    padding: 8px 18px; border-radius: 999px;
    font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  }

  /* SUBMIT BAR */
  .submit-bar { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); border-top: 3px solid var(--navy); padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; z-index: 100; transform: translateY(100%); transition: transform 0.3s ease; box-shadow: 0 -4px 24px rgba(10,31,68,0.1); }
  .submit-bar.visible { transform: translateY(0); }
  .submit-bar-text { font-size: 14px; color: var(--muted); }
  .submit-bar-text strong { color: var(--navy); }
  .submit-btn { background: var(--red); color: #fff; border: none; border-radius: 8px; padding: 12px 28px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: opacity 0.2s; white-space: nowrap; }
  .submit-btn:hover { opacity: 0.88; }

  /* MODAL */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(10,31,68,0.6); z-index: 200; align-items: center; justify-content: center; padding: 24px; }
  .modal-overlay.open { display: flex; }
  .modal { background: #fff; border: 2px solid var(--navy); border-top: 5px solid var(--red); border-radius: 20px; padding: 36px; max-width: 460px; width: 100%; text-align: center; }
  .modal-icon { font-size: 44px; margin-bottom: 14px; }
  .modal h2 { font-family: 'Bebas Neue', sans-serif; font-size: 30px; letter-spacing: 2px; margin-bottom: 8px; color: var(--navy); }
  .modal p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-bottom: 24px; }
  .modal-choice { background: rgba(10,31,68,0.05); border: 1px solid rgba(10,31,68,0.2); border-left: 4px solid var(--red); border-radius: 10px; padding: 12px 18px; margin-bottom: 20px; font-weight: 700; color: var(--navy); font-size: 14px; text-align: left; }
  .modal-btn { background: var(--navy); color: #fff; border: none; border-radius: 10px; padding: 13px 28px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; width: 100%; margin-bottom: 10px; transition: opacity 0.2s; }
  .modal-btn:hover { opacity: 0.88; }
  .modal-cancel { background: transparent; border: 1px solid var(--border); color: var(--muted); border-radius: 10px; padding: 11px; font-size: 13px; cursor: pointer; width: 100%; font-family: 'Inter', sans-serif; }

  /* ══ CUSTOM PROMPT PAGE ══ */
  .custom-screen { display: none; position: fixed; inset: 0; background: var(--off-white); z-index: 400; overflow-y: auto; padding: 40px 24px 60px; }
  .custom-screen.show { display: block; }

  .custom-inner { max-width: 600px; margin: 0 auto; }

  .custom-header { text-align: center; margin-bottom: 36px; }
  .custom-header .logo-row { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 16px; }
  .custom-header .logo-row img { width: 100px; filter: brightness(0) saturate(100%) invert(8%) sepia(63%) saturate(1200%) hue-rotate(200deg) brightness(90%) contrast(110%); }
  .custom-header .logo-row span { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 3px; color: var(--navy); }
  .custom-header h2 { font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 2px; color: var(--navy); margin-bottom: 8px; }
  .custom-header h2 em { color: var(--red); font-style: normal; }
  .custom-header p { color: var(--muted); font-size: 14px; line-height: 1.6; }

  .selected-concept-preview { background: #fff; border: 2px solid var(--border); border-left: 4px solid var(--red); border-radius: 12px; padding: 14px 18px; margin-bottom: 28px; display: flex; align-items: center; gap: 12px; }
  .scp-icon { font-size: 24px; }
  .scp-text { font-size: 13px; color: var(--muted); }
  .scp-text strong { color: var(--navy); display: block; font-size: 14px; margin-bottom: 2px; }

  .prompt-box-wrap { margin-bottom: 20px; }
  .prompt-box-wrap label { display: block; font-size: 13px; font-weight: 700; color: var(--navy); letter-spacing: 0.5px; margin-bottom: 8px; }
  .prompt-textarea { width: 100%; min-height: 130px; padding: 14px 16px; border: 2px solid var(--border); border-radius: 12px; font-family: 'Inter', sans-serif; font-size: 14px; color: var(--text); resize: vertical; outline: none; transition: border-color 0.2s; line-height: 1.6; background: #fff; }
  .prompt-textarea:focus { border-color: var(--navy); }
  .prompt-hint { font-size: 12px; color: var(--muted); margin-top: 6px; line-height: 1.5; }

  .prompt-submit-btn { width: 100%; padding: 14px; background: var(--navy); color: #fff; border: none; border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: opacity 0.2s; margin-bottom: 12px; }
  .prompt-submit-btn:hover { opacity: 0.88; }
  .prompt-submit-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .skip-btn { width: 100%; padding: 11px; background: transparent; border: 1px solid var(--border); color: var(--muted); border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 13px; cursor: pointer; }

  /* Custom generating screen */
  .custom-generating { display: none; text-align: center; padding: 40px 0; }
  .custom-generating.show { display: block; }
  .custom-form-area.hidden { display: none; }

  .mini-ring-wrap { position: relative; width: 120px; height: 120px; margin: 0 auto 20px; }
  .mini-ring-wrap svg { position: absolute; inset: 0; transform: rotate(-90deg); }
  .mini-ring-bg { fill: none; stroke: var(--border); stroke-width: 5; }
  .mini-ring-progress { fill: none; stroke: var(--red); stroke-width: 5; stroke-linecap: round; stroke-dasharray: 314; stroke-dashoffset: 0; transition: stroke-dashoffset 1s linear; }
  .mini-cd-number { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 44px; color: var(--navy); }
  .custom-generating h3 { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 2px; color: var(--navy); margin-bottom: 8px; }
  .custom-generating p { color: var(--muted); font-size: 14px; line-height: 1.6; }

  /* Custom result */
  .custom-result { display: none; text-align: center; }
  .custom-result.show { display: block; }
  .custom-result-img { width: 100%; border-radius: 12px; border: 2px solid var(--border); margin-bottom: 20px; }
  .custom-result h3 { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px; color: var(--navy); margin-bottom: 8px; }
  .custom-result p { color: var(--muted); font-size: 14px; margin-bottom: 20px; }
  .choose-custom-btn { width: 100%; padding: 14px; background: var(--red); color: #fff; border: none; border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; margin-bottom: 10px; transition: opacity 0.2s; }
  .choose-custom-btn:hover { opacity: 0.88; }
  .try-again-btn { width: 100%; padding: 11px; background: transparent; border: 1px solid var(--border); color: var(--muted); border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 13px; cursor: pointer; }

  /* SUCCESS */
  .success-screen { display: none; position: fixed; inset: 0; background: var(--navy); z-index: 600; align-items: center; justify-content: center; flex-direction: column; gap: 14px; text-align: center; padding: 40px; }
  .success-screen.show { display: flex; }
  .success-logo { width: 120px; filter: brightness(0) invert(1); opacity: 0.7; margin-bottom: 4px; }
  .success-screen .big-icon { font-size: 64px; }
  .success-screen h2 { font-family: 'Bebas Neue', sans-serif; font-size: 38px; letter-spacing: 3px; color: #fff; }
  .success-screen h2 span { color: var(--red); }
  .success-screen p { color: rgba(255,255,255,0.6); font-size: 14px; max-width: 380px; line-height: 1.6; }
  .success-screen .powered { font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 8px; }
  .success-screen .powered span { color: rgba(200,16,46,0.6); }

  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
    .submit-bar { flex-direction: column; align-items: stretch; }
    .progress-steps { flex-direction: column; gap: 10px; }
  }
</style>
</head>
<body>

<!-- ══ COUNTDOWN ══ -->
<div class="countdown-screen" id="countdown-screen">
  <div class="cd-logo-wrap">
    <img src="https://jointailgate.com/wp-content/uploads/2026/02/tailgate-light.png" alt="Tailgate Fundraising" class="cd-logo-img">
    <div class="cd-brand">Tailgate <span>Fundraising</span></div>
    <div class="cd-powered">Designs powered by Tailgate AI — built to bring you the best experience</div>
  </div>
  <div class="cd-label">Generating Your Concepts</div>
  <div class="ring-wrap">
    <svg viewBox="0 0 180 180" width="180" height="180">
      <circle class="ring-bg" cx="90" cy="90" r="80"/>
      <circle class="ring-progress" id="ring" cx="90" cy="90" r="80"/>
    </svg>
    <div class="cd-number" id="countdown-number">90</div>
  </div>
  <div class="cd-msg">
    <strong>Your 4 custom card concepts are being created.</strong><br>
    Our AI is designing unique options just for your organization<span class="dots"><span>.</span><span>.</span><span>.</span></span>
  </div>
  <div class="progress-steps">
    <div class="ps active" id="ps-a"><div class="dot"></div> Concept 1</div>
    <div class="ps" id="ps-b"><div class="dot"></div> Concept 2</div>
    <div class="ps" id="ps-c"><div class="dot"></div> Concept 3</div>
    <div class="ps" id="ps-d"><div class="dot"></div> Concept 4</div>
  </div>
