<!-- SUCCESS -->
<div class="success-screen" id="success-screen">
  <img src="https://jointailgate.com/wp-content/uploads/2026/02/tailgate-light.png" alt="Tailgate Fundraising" class="success-logo">
  <div class="big-icon">🏆</div>
  <h2>Choice <span>Submitted!</span></h2>
  <p>Your design team has been notified and will begin finalizing your card.</p>
  <p style="font-size:13px;margin-top:4px;color:rgba(255,255,255,0.4);">You can close this window.</p>
  <div class="powered">Designs powered by <span>Tailgate AI</span></div>
</div>


<script>
  // ═══════════════════════════════════════════
  // CONFIG — fill these in
  // ═══════════════════════════════════════════
  const OPENAI_KEY           = '';
  const ZOHO_GET_IMAGES_URL  = 'https://flow.zoho.com/896289513/flow/webhook/incoming?zapikey=1001.867d9de8fbd1d84ec91c34fbdc1b848f.6bba4fce1b2ad9c81de6ba0430637a2e&isdebug=false';
  const ZOHO_SUBMIT_URL      = 'https://flow.zoho.com/896289513/flow/webhook/incoming?zapikey=1001.ee4235fe14924658155a75e5f08ed7d4.03a8eb9cb7e291134347f83903ab5189&isdebug=false';

  // ═══════════════════════════════════════════
  // URL PARAMS (org name passed from Zoho Forms redirect)
  // ═══════════════════════════════════════════
  const params  = new URLSearchParams(window.location.search);
  const orgName = params.get('org')   || 'Your Organization';
  const email   = params.get('email') || '';

  // These will be populated after Creator fetch
  let img1 = '', img2 = '', img3 = '', img4 = '';

  // ═══════════════════════════════════════════
  // COUNTDOWN
  // ═══════════════════════════════════════════
  const TOTAL        = 90;
  const circumference = 2 * Math.PI * 80; // 502.65
  let timeLeft       = TOTAL;

  const ring   = document.getElementById('ring');
  const numEl  = document.getElementById('countdown-number');
  const psEls  = ['ps-a','ps-b','ps-c','ps-d'].map(id => document.getElementById(id));
  const milestones = [68, 46, 24, 2];

  ring.style.strokeDasharray  = circumference;
  ring.style.strokeDashoffset = 0;

  const timer = setInterval(() => {
    timeLeft--;
    numEl.textContent = timeLeft;
    ring.style.strokeDashoffset = circumference * ((TOTAL - timeLeft) / TOTAL);

    milestones.forEach((m, i) => {
      if (timeLeft <= m) {
        psEls[i].classList.remove('active');
        psEls[i].classList.add('done');
        if (i + 1 < psEls.length && !psEls[i+1].classList.contains('done')) {
          psEls[i+1].classList.add('active');
        }
      }
    });

    if (timeLeft <= 0) {
      clearInterval(timer);
      revealConcepts();
    }
  }, 1000);

  // ═══════════════════════════════════════════
  // FETCH IMAGES FROM ZOHO FLOW PROXY
  // ═══════════════════════════════════════════
  async function fetchImages(retries = 4) {
    for (let i = 0; i < retries; i++) {
      try {
        const res = await fetch(ZOHO_GET_IMAGES_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ org: orgName, request: 'get_images' })
        });
        const data = await res.json();
        console.log('Flow response:', data);
        if (data.img1 || data.img2) return data;
        throw new Error('No images yet');
      } catch(e) {
        console.warn('Fetch attempt ' + (i+1) + ' failed:', e);
        if (i < retries - 1) await new Promise(r => setTimeout(r, 2500));
      }
    }
    return null;
  }

  // ═══════════════════════════════════════════
  // REVEAL AFTER COUNTDOWN
  // ═══════════════════════════════════════════
  async function revealConcepts() {
    document.getElementById('countdown-screen').classList.add('hidden');
    document.getElementById('main-content').classList.add('visible');
    document.getElementById('org-badge').textContent = orgName;

    const data = await fetchImages();
    if (data) {
      img1 = data.img1 || '';
      img2 = data.img2 || '';
      img3 = data.img3 || '';
      img4 = data.img4 || '';
      loadImage('img-1', img1);
      loadImage('img-2', img2);
      loadImage('img-3', img3);
      loadImage('img-4', img4);
    } else {
      showRetryBanner();
    }
  }

  function showRetryBanner() {
    const banner = document.createElement('div');
    banner.style.cssText = 'text-align:center;padding:14px;background:#fff3f3;border-bottom:2px solid #C8102E;font-size:14px;color:#C8102E;font-weight:600;';
    banner.innerHTML = '⚠️ Images still loading — <a href="javascript:retryLoad()" style="color:#0A1F44;text-decoration:underline;cursor:pointer;">Click here to retry</a>';
    document.getElementById('main-content').prepend(banner);
  }

  async function retryLoad() {
    const data = await fetchImages();
    if (data) {
      img1 = data.img1 || '';
      img2 = data.img2 || '';
      img3 = data.img3 || '';
      img4 = data.img4 || '';
      loadImage('img-1', img1);
      loadImage('img-2', img2);
      loadImage('img-3', img3);
      loadImage('img-4', img4);
      const banner = document.querySelector('[style*="fff3f3"]');
      if (banner) banner.remove();
    }
  }

  function loadImage(id, url) {
    const c = document.getElementById(id);
    if (!url) {
      c.innerHTML = '<div class="error-placeholder"><div class="error-icon">🎨</div><div class="error-text">Still Generating</div><div class="error-sub">Check back in a moment</div></div>';
      return;
    }
    const img = document.createElement('img');
    img.src = url;
    img.alt = 'Concept design';
    img.onerror = () => {
      c.innerHTML = '<div class="error-placeholder"><div class="error-icon">⚠️</div><div class="error-text">Image Unavailable</div><div class="error-sub">Please retry</div></div>';
    };
    c.innerHTML = '';
    c.appendChild(img);
  }

  // ═══════════════════════════════════════════
  // SELECTION
  // ═══════════════════════════════════════════
  let selectedOption = null, selectedLabel = null, selectedImgUrl = null;

  function selectCard(card) {
    document.querySelectorAll('.card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedOption = card.dataset.option;
    selectedLabel  = card.dataset.label;
    const imgMap   = { '1': img1, '2': img2, '3': img3, '4': img4 };
    selectedImgUrl = imgMap[selectedOption] || '';
    document.getElementById('bar-selection').textContent = 'Option ' + selectedOption + ' — ' + selectedLabel;
    document.getElementById('submit-bar').classList.add('visible');
    document.getElementById('modal-choice-label').textContent = 'Option ' + selectedOption + ' — ' + selectedLabel;
  }

  function openModal()  { if (!selectedOption) return; document.getElementById('modal').classList.add('open'); }
  function closeModal() { document.getElementById('modal').classList.remove('open'); }

  // ═══════════════════════════════════════════
  // CUSTOM PROMPT PAGE
  // ═══════════════════════════════════════════
  function openCustomDirect() {
    document.getElementById('scp').style.display = 'none';
    document.getElementById('submit-bar').classList.remove('visible');
    document.getElementById('custom-screen').classList.add('show');
    populateConceptPreviews();
    window.scrollTo(0, 0);
  }

  function openCustomPrompt() {
    closeModal();
    document.getElementById('scp-label').textContent = 'Option ' + selectedOption + ' — ' + selectedLabel;
    document.getElementById('custom-screen').classList.add('show');
    populateConceptPreviews();
    window.scrollTo(0, 0);
  }

  function populateConceptPreviews() {
    const imgs = [img1, img2, img3, img4];
    imgs.forEach((url, i) => {
      if (!url) return;
      const el = document.getElementById('cvb-img-' + (i + 1));
      if (!el) return;
      const imgTag = document.createElement('img');
      imgTag.src = url;
      imgTag.className = 'cvb-img';
      imgTag.alt = 'Concept ' + (i + 1);
      el.replaceWith(imgTag);
    });
  }

  function useConceptAsBase(num, label) {
    document.querySelectorAll('.concept-var-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('cvb-' + num).classList.add('active');
    const textarea = document.getElementById('custom-prompt-input');
    textarea.value = 'Same style as Option ' + num + ' (' + label + ') but ';
    textarea.focus();
    textarea.setSelectionRange(textarea.value.length, textarea.value.length);
  }

  function goBackToGrid() {
    document.getElementById('custom-screen').classList.remove('show');
    document.getElementById('custom-result').classList.remove('show');
    document.getElementById('custom-form-area').classList.remove('hidden');
    document.getElementById('custom-prompt-input').value = '';
    customResultUrl = null;
    window.scrollTo(0, 0);
  }

  // ═══════════════════════════════════════════
  // CUSTOM DALL-E GENERATION
  // ═══════════════════════════════════════════
  let customResultUrl = null;

  function submitCustomPrompt() {
    const promptText = document.getElementById('custom-prompt-input').value.trim();
    if (!promptText) { alert('Please describe your concept first.'); return; }

    document.getElementById('custom-form-area').classList.add('hidden');
    document.getElementById('custom-result').classList.remove('show');

    const genEl = document.getElementById('custom-generating');
    genEl.classList.add('show');

    // 30 second mini countdown
    let miniTime    = 30;
    const miniRing  = document.getElementById('mini-ring');
    const miniNum   = document.getElementById('mini-number');
    const miniCirc  = 2 * Math.PI * 44;
    miniRing.style.strokeDasharray  = miniCirc;
    miniRing.style.strokeDashoffset = 0;

    const miniTimer = setInterval(() => {
      miniTime--;
      miniNum.textContent = miniTime;
      miniRing.style.strokeDashoffset = miniCirc * ((30 - miniTime) / 30);
      if (miniTime <= 0) clearInterval(miniTimer);
    }, 1000);

    const fullPrompt = 'Create a bold horizontal fundraiser card concept. Composition designed for a wide horizontal rectangle similar to a business card landscape orientation — keep all important visual elements away from edges and leave clean space along the bottom edge for text overlay. No text anywhere in the image. High detail. Vivid style. ' + promptText;

    fetch('https://api.openai.com/v1/images/generations', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + OPENAI_KEY
      },
      body: JSON.stringify({
        model: 'dall-e-3',
        prompt: fullPrompt,
        n: 1,
        size: '1792x1024',
        quality: 'hd',
        style: 'vivid'
      })
    })
    .then(r => r.json())
    .then(data => {
      clearInterval(miniTimer);
      customResultUrl = data.data[0].url;
      genEl.classList.remove('show');
      document.getElementById('custom-result-img').src = customResultUrl;
      document.getElementById('custom-result').classList.add('show');
    })
    .catch(e => {
      clearInterval(miniTimer);
      console.error('DALL-E error:', e);
      genEl.classList.remove('show');
      document.getElementById('custom-form-area').classList.remove('hidden');
      alert('Something went wrong — please try again.');
    });
  }

  function tryAgain() {
    customResultUrl = null;
    document.getElementById('custom-result').classList.remove('show');
    document.getElementById('custom-prompt-input').value = '';
    document.getElementById('custom-form-area').classList.remove('hidden');
  }

  function submitCustomConcept() {
    const promptText = document.getElementById('custom-prompt-input').value.trim();
    sendToZoho('Custom Prompt', customResultUrl, promptText);
  }

  // ═══════════════════════════════════════════
  // SUBMIT TO ZOHO FLOW
  // ═══════════════════════════════════════════
  function submitChoice() {
    closeModal();
    sendToZoho(selectedLabel, selectedImgUrl, '');
  }

  function finalSubmit() {
    sendToZoho(selectedLabel, selectedImgUrl, '');
  }

  function sendToZoho(label, imgUrl, customPrompt) {
    const isCustom = (label === 'Custom Prompt');
    const payload = {
      org:              orgName,
      email:            email,
      selected_option:  selectedOption || 'Custom',
      selected_label:   label,
      selected_img:     imgUrl || '',
      custom_prompt:    customPrompt || '',
      image_5_custom:   isCustom ? (imgUrl || '') : '',
      img1_url:         img1,
      img2_url:         img2,
      img3_url:         img3,
      img4_url:         img4,
      timestamp:        new Date().toISOString()
    };

    console.log('Submitting to Zoho:', payload);

    fetch(ZOHO_SUBMIT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(r => console.log('Submitted, status:', r.status))
    .catch(e => console.error('Submit error:', e));

    document.getElementById('custom-screen').classList.remove('show');
    document.getElementById('modal').classList.remove('open');
    document.getElementById('success-screen').classList.add('show');
  }
</script>

</body>
